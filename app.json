{
  "expo": {
    "name": "AsianLeStaff",
    "slug": "AsianLeStaff",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "asianlestaff",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.buivuanhhuy.AsianLeStaff"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "196e6d9a-3ab3-451c-9df9-1c742f2c3f22"
      }
    }
  }
}
